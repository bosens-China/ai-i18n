{
  "name": "@ai-i18n/ai-i18n",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsdown",
    "examples:dev": "pnpm build && turbo run dev --filter='@ai-i18n/example-*'",
    "examples:build": "pnpm build && turbo run build --filter='@ai-i18n/example-*'",
    "examples:preview": "turbo run preview --filter='@ai-i18n/example-*'",
    "docs:dev": "pnpm build && turbo run dev --filter='@ai-i18n/docs' --filter='@ai-i18n/example-*'",
    "docs:build": "pnpm examples:build && pnpm --filter @ai-i18n/docs build",
    "check": "pnpm build && tsc -p tsconfig.json && eslint \"*.config.{js,ts}\" && pnpm -r --if-present run check",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm check && pnpm test && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.5",
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.10.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.8.3",
    "publint": "0.3.22",
    "tsdown": "0.22.13",
    "turbo": "^2.10.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
