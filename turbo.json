{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "i18n/**",
        "index.html",
        "vite.config.ts",
        "tsconfig*.json",
        "package.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "check": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "cache": false
    }
  }
}
