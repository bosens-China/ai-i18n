{
  "name": "@ai-i18n/vite",
  "version": "1.0.0-alpha.1",
  "description": "Vite 8 static extraction and browser runtime plugin for ai-i18n.",
  "keywords": [
    "i18n",
    "translation",
    "vite"
  ],
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "analyzer.d.ts",
    "analyzer.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analyzer": {
      "types": "./analyzer.d.ts",
      "import": "./analyzer.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/vite/test --config vitest.config.ts",
    "benchmark": "node benchmark/yuku-spike.mjs"
  },
  "dependencies": {
    "@ai-i18n/analyzer": "workspace:^",
    "@ai-i18n/core": "workspace:^",
    "magic-string": "0.30.21",
    "parse5": "8.0.0",
    "yuku-analyzer": "0.7.3"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.5.0",
    "react": "^18.3.0 || ^19.0.0",
    "vite": "^8.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vue/compiler-sfc": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/compiler-sfc": "^3.5.34",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
