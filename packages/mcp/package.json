{
  "name": "@ai-i18n/mcp",
  "version": "1.0.0-alpha.1",
  "description": "Local MCP tools for reading and filling ai-i18n translation files.",
  "keywords": [
    "i18n",
    "mcp",
    "translation"
  ],
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ai-i18n-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/mcp/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
