{
  "name": "@ai-i18n/core",
  "version": "0.0.0",
  "description": "Framework-independent schemas, provider contracts, and browser runtime for ai-i18n.",
  "keywords": [
    "i18n",
    "translation",
    "vite"
  ],
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/core/test --config vitest.config.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}
