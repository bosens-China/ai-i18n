{
  "name": "@ai-i18n/analyzer",
  "version": "0.0.0",
  "description": "Shared Yuku-based static translation analysis for ai-i18n tooling.",
  "keywords": [
    "i18n",
    "static-analysis",
    "translation"
  ],
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git",
    "directory": "packages/analyzer"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/analyzer/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:^",
    "source-map-js": "1.2.1",
    "yuku-analyzer": "0.7.3"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vue/compiler-sfc": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vue/compiler-sfc": "^3.5.34"
  }
}
