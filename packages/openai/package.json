{
  "name": "@ai-i18n/openai",
  "version": "0.0.0",
  "description": "Fetch-based OpenAI-compatible translation provider for ai-i18n.",
  "keywords": ["i18n", "openai", "translation"],
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:*"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
