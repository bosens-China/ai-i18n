{
  "name": "@ai-i18n/openai",
  "version": "1.0.0-alpha.1",
  "description": "LangChain-based OpenAI-compatible translation provider for ai-i18n.",
  "keywords": [
    "i18n",
    "openai",
    "translation"
  ],
  "license": "MIT",
  "author": "yliu",
  "homepage": "https://github.com/bosens-China/ai-i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosens-China/ai-i18n.git",
    "directory": "packages/openai"
  },
  "bugs": {
    "url": "https://github.com/bosens-China/ai-i18n/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/openai/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:^",
    "@langchain/core": "^1.2.3",
    "@langchain/openai": "^1.5.5",
    "langsmith": "^0.8.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
