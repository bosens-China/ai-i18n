{
  "name": "@ai-i18n/openai",
  "version": "0.0.0",
  "description": "LangChain-based OpenAI-compatible translation provider for ai-i18n.",
  "keywords": [
    "i18n",
    "openai",
    "translation"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/openai/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:*",
    "@langchain/core": "^1.2.3",
    "@langchain/openai": "^1.5.5",
    "langsmith": "^0.8.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
