{
  "name": "@ai-i18n/react",
  "version": "0.0.0",
  "description": "React bindings and optional Vite extractor for ai-i18n.",
  "keywords": [
    "i18n",
    "react",
    "translation",
    "vite"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/react/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/core": "workspace:*"
  },
  "peerDependencies": {
    "@ai-i18n/vite": "workspace:*",
    "react": "^18.3.0 || ^19.0.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-i18n/vite": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ai-i18n/vite": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
