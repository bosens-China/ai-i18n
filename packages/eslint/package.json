{
  "name": "@ai-i18n/eslint-plugin",
  "version": "0.0.0",
  "description": "ESLint 9 static-argument checks aligned with ai-i18n extraction semantics.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "i18n",
    "translation"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "check": "tsc -p tsconfig.json --noEmit && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/eslint/test --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-i18n/analyzer": "workspace:*"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.5.0",
    "eslint": "^9.0.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/compiler-sfc": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vue/compiler-sfc": "^3.5.34",
    "vue-eslint-parser": "^10.4.1"
  }
}
