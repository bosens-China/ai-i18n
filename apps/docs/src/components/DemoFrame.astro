---
/**
 * 嵌入独立 Vite example。
 * - 开发：iframe 指向 localhost 上的 dev server
 * - 构建/部署：iframe 指向同域静态 examples 产物
 */
import {
  demoDevUrl,
  demoProdUrl,
  type DemoFramework,
} from '../lib/demo-urls';

interface Props {
  framework: DemoFramework;
  title: string;
  description: string;
}

const { framework, title, description } = Astro.props;
const href = import.meta.env.DEV
  ? demoDevUrl(framework)
  : demoProdUrl(framework, import.meta.env.BASE_URL);

const accents: Record<DemoFramework, string> = {
  vanilla: '#f59e0b',
  vue: '#10b981',
  react: '#2563eb',
};
const accent = accents[framework];
---

<section class="demo-section" style={`--demo-accent: ${accent}`}>
  <header class="demo-header">
    <div class="demo-heading">
      <span class="demo-badge">{framework}</span>
      <div>
        <h2 id={framework}>{title}</h2>
        <p>{description}</p>
      </div>
    </div>
    <a class="demo-open" href={href} target="_blank" rel="noreferrer">
      单独打开
      <span aria-hidden="true">↗</span>
    </a>
  </header>
  <div class="demo-shell">
    <iframe class="demo-frame" src={href} title={title} loading="lazy"></iframe>
  </div>
</section>

<style>
  .demo-section {
    margin-block: 3rem;
  }

  .demo-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .demo-heading {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    min-width: 0;
  }

  .demo-badge {
    flex-shrink: 0;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--demo-accent) 14%, transparent);
    color: var(--demo-accent);
    font-family: var(--sl-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--demo-accent) 26%, transparent);
  }

  .demo-heading h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
  }

  .demo-heading p {
    margin: 0.35rem 0 0;
    color: var(--sl-color-gray-3);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .demo-open {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    padding: 0.45rem 0.95rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    font-size: 0.84rem;
    font-weight: 500;
    text-decoration: none;
    background: color-mix(in srgb, var(--sl-color-bg) 80%, transparent);
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .demo-open:hover {
    color: var(--sl-color-accent);
    border-color: var(--demo-accent);
    background: color-mix(in srgb, var(--demo-accent) 12%, transparent);
    transform: translateY(-1px);
  }

  .demo-open span {
    transition: transform 160ms ease;
  }

  .demo-open:hover span {
    transform: translate(2px, -2px);
  }

  .demo-shell {
    overflow: hidden;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1.15rem;
    background: var(--sl-color-bg);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 16px 40px rgba(15, 23, 42, 0.08);
    transition: box-shadow 220ms ease;
  }

  .demo-shell:hover {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 20px 50px rgba(15, 23, 42, 0.14);
  }

  .demo-frame {
    display: block;
    width: 100%;
    height: 22rem;
    border: 0;
    background: var(--sl-color-bg);
  }

  @media (max-width: 640px) {
    .demo-header {
      flex-direction: column;
    }

    .demo-open {
      align-self: flex-start;
    }

    .demo-frame {
      height: 24rem;
    }
  }
</style>
