---
/**
 * 嵌入独立 Vite example 构建产物。
 * 文档站不挂载 @boses/vite，避免单 build 多 framework 冲突。
 */
interface Props {
  framework: 'vanilla' | 'vue' | 'react';
  title: string;
}

const { framework, title } = Astro.props;
const href = `${import.meta.env.BASE_URL}examples/${framework}/`;
---

<section class="demo-section">
  <div class="demo-toolbar">
    <h2 id={framework}>{title}</h2>
    <a href={href} target="_blank" rel="noreferrer">单独打开</a>
  </div>
  <iframe class="demo-frame" src={href} title={title} loading="lazy"></iframe>
</section>

<style>
  .demo-section {
    margin-block: 1.5rem;
  }

  .demo-toolbar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .demo-toolbar h2 {
    margin: 0;
  }

  .demo-frame {
    display: block;
    width: 100%;
    height: 28rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7);
  }
</style>
