---
/**
 * 在默认站点标题旁增加「演示 / 文档 / 配置与 API」主导航。
 * GitHub 由 Starlight social 配置渲染。
 */
import Default from '@astrojs/starlight/components/SiteTitle.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const pathname = Astro.url.pathname.replace(/\/$/, '');
const isDemo = pathname.endsWith('/demo');
const isReference =
  pathname.endsWith('/api') || pathname.includes('/api/');
const isDocs = !isDemo && !isReference;
---

<div class="title-with-nav">
  <Default><slot /></Default>
  <nav class="site-nav" aria-label="主导航">
    <a href={base} aria-current={isDocs ? 'page' : undefined}>文档</a>
    <a
      href={`${base}api/vite/`}
      aria-current={isReference ? 'page' : undefined}>配置与 API</a
    >
    <a href={`${base}demo/`} aria-current={isDemo ? 'page' : undefined}>演示</a>
  </nav>
</div>

<style>
  .title-with-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    min-width: 0;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-bg) 80%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: var(--sl-text-xs);
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
  }

  .site-nav a {
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    font-weight: 500;
    transition:
      color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .site-nav a:hover {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .site-nav a:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .site-nav a[aria-current='page'] {
    background: var(--brand-gradient, linear-gradient(135deg, #2563eb, #7c3aed));
    color: #ffffff !important;
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  @media (max-width: 50rem) {
    .title-with-nav {
      gap: 0.5rem;
    }

    .site-nav a {
      padding-inline: 0.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav a {
      transition: none;
    }
  }
</style>
